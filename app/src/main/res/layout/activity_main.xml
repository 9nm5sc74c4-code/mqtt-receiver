<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo 区域 -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:background="@drawable/ic_launcher_background"
            android:backgroundTint="#1565C0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M"
                android:textColor="@android:color/white"
                android:textSize="40sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MQTT Receiver"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="实时数据仪表盘"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <!-- 连接状态 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="输入连接信息开始"
            android:textSize="13sp"
            android:textColor="#999999"
            android:background="@drawable/status_bar_bg" />

        <!-- 上次连接 -->
        <TextView
            android:id="@+id/tv_last_connect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- 进度指示器 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            android:indeterminateTint="#1565C0" />

        <!-- 登录/连接卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="16dp"
            app:contentPadding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MQTT 连接配置"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="16dp" />

                <!-- Broker -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:hint="Broker 地址">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_broker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:text="ie1d91ad.ala.cn-hangzhou.emqxsl.cn" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 端口和主题一行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:hint="端口">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_port"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:singleLine="true"
                            android:text="8883" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:hint="订阅主题">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_topic"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:singleLine="true"
                            android:text="ch6pem2" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- 用户名 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:hint="用户名（可选）">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:singleLine="true" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 密码（带可见性切换） -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:hint="密码（可选）">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:singleLine="true"
                            android:paddingEnd="48dp" />

                        <ImageView
                            android:id="@+id/iv_toggle_password"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignEnd="@id/et_password"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="8dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:contentDescription="显示密码"
                            android:clickable="true"
                            android:focusable="true" />
                    </RelativeLayout>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 开机自启 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="记住凭据并自动连接"
                        android:textSize="14sp"
                        android:textColor="#555555" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_auto_connect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />

                </LinearLayout>

                <!-- 连接按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_connect"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="🔌 连接 MQTT Broker"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#1565C0" />

                <!-- 清除凭据 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_config"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:text="清除已保存的凭据"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="#999999" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
