<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- 工具栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#161B22"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="等待数据..."
            android:textSize="12sp"
            android:textColor="#8B949E"
            android:layout_marginEnd="8dp" />

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- 信息栏 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardElevation="0dp"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="#161B22"
        app:strokeWidth="1dp"
        app:strokeColor="#30363D"
        app:contentPadding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_topic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="主题: --"
                    android:textSize="13sp"
                    android:textColor="#C9D1D9" />

                <TextView
                    android:id="@+id/tv_update_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#8B949E"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="↻"
                    android:textSize="18sp"
                    android:textColor="#58A6FF"
                    app:iconTint="#58A6FF"
                    app:cornerRadius="18dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="📋"
                    android:textSize="16sp"
                    android:textColor="#58A6FF"
                    app:cornerRadius="18dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="↗"
                    android:textSize="18sp"
                    android:textColor="#58A6FF"
                    app:cornerRadius="18dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- JSON 内容 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:layout_marginTop="0dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#0D1117"
            app:strokeWidth="1dp"
            app:strokeColor="#30363D"
            app:contentPadding="0dp">

            <TextView
                android:id="@+id/tv_json_raw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="#C9D1D9"
                android:lineSpacingExtra="4dp"
                android:padding="12dp"
                android:background="#0D1117"
                android:text="暂无数据\n\n连接 MQTT 后数据将自动显示在这里" />

        </com.google.android.material.card.MaterialCardView>

    </ScrollView>

</LinearLayout>
