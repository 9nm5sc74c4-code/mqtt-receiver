<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- 顶部栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1A73E8"
        app:title="📊 数据仪表盘"
        app:titleTextColor="@android:color/white"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/tv_connection_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已连接"
                android:textSize="10sp"
                android:textColor="#B3E5FC"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_disconnect"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="断开"
                android:textSize="12sp"
                android:textColor="#FFCDD2"
                android:backgroundTint="#C62828"
                app:cornerRadius="16dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 状态卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardElevation="3dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:contentPadding="14dp"
                app:strokeWidth="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- 状态指示灯 -->
                    <LinearLayout
                        android:id="@+id/status_indicator"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:background="@drawable/circle_status_bg"
                        android:padding="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="●"
                            android:textColor="#34A853"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_topic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/status_indicator"
                        android:layout_marginStart="14dp"
                        android:text="主题: --"
                        android:textSize="14sp"
                        android:textColor="#202124"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_update_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/status_indicator"
                        android:layout_below="@id/tv_topic"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="2dp"
                        android:text="等待数据..."
                        android:textSize="12sp"
                        android:textColor="#5F6368" />
                </RelativeLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 数据区标题栏 + 操作按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📈 实时数据"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#202124" />

                <TextView
                    android:id="@+id/tv_value_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 个字段"
                    android:textSize="12sp"
                    android:textColor="#80868B"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_data"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="52dp"
                    android:layout_height="28dp"
                    android:text="清除"
                    android:textSize="11sp"
                    android:textColor="#5F6368"
                    android:backgroundTint="#E8EAED"
                    app:cornerRadius="14dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp" />

            </LinearLayout>

            <!-- 数据卡片容器 -->
            <LinearLayout
                android:id="@+id/data_card_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 空状态占位 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/empty_state_card"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginBottom="4dp"
                    app:cardElevation="1dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:contentPadding="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📡"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="等待 MQTT 数据..."
                            android:textSize="14sp"
                            android:textColor="#80868B"
                            android:layout_marginTop="6dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="连接成功后数据将自动显示"
                            android:textSize="12sp"
                            android:textColor="#BDC1C6"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- 查看原始 JSON 按钮 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:contentPadding="0dp"
                app:strokeWidth="0dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:id="@+id/card_view_json">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="4dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="📄"
                        android:textSize="18sp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/circle_icon_bg" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="原始 JSON 数据"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#202124" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="查看完整的 JSON 数据详情"
                            android:textSize="11sp"
                            android:textColor="#5F6368"
                            android:layout_marginTop="1dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="#BDC1C6" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
